# ============================================================
# Campus Intelligence — Environment Variables
# Copy this file to orchestrator/.env and fill in your values
# ============================================================

# ------------------------------------------------------------
# REQUIRED: Groq API Key
# Get a free key at https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=

# ------------------------------------------------------------
# OPTIONAL: LLM Model
# Default: llama-3.3-70b-versatile
# Other options: llama-3.1-8b-instant (faster, less capable)
# ------------------------------------------------------------
LLM_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------
# OPTIONAL: Orchestrator port (default: 4000)
# ------------------------------------------------------------
PORT=4000

# ------------------------------------------------------------
# OPTIONAL: MCP Server URLs (defaults shown)
# Only change if you run servers on non-default ports
# ------------------------------------------------------------
LIBRARY_MCP_URL=http://localhost:5001/sse
CAFETERIA_MCP_URL=http://localhost:5002/sse
EVENTS_MCP_URL=http://localhost:5003/sse
ACADEMICS_MCP_URL=http://localhost:5004/sse

# ------------------------------------------------------------
# Frontend (.env.local in /frontend — optional override)
# ------------------------------------------------------------
# ORCHESTRATOR_URL=http://localhost:4000
